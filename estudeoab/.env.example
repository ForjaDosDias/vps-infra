# ─────────────────────────────────────────────
# EstudeOAB — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env real.
# ─────────────────────────────────────────────

# Segredo para assinar tokens JWT de autenticação.
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Chave de API do DeepSeek para extração de questões via IA.
# Obtenha em: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Modelo DeepSeek a utilizar (padrão: deepseek-chat = DeepSeek-V3).
# Opções disponíveis: deepseek-chat, deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# Chave de API do Resend para envio de e-mails transacionais.
# Crie em: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Endereço de remetente dos e-mails (deve estar verificado no Resend).
RESEND_FROM=noreply@aprovanoab.com.br

# URL pública do frontend (usada nos links dos e-mails).
APP_URL=https://aprovanoab.com.br
